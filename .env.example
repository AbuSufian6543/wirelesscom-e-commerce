# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/radio_store?schema=public"

# Auth
AUTH_SECRET="change-me-to-a-long-random-string-in-production"
NEXTAUTH_URL="http://localhost:3000"

# PayPal (use sandbox keys for development)
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_MODE="sandbox"
NEXT_PUBLIC_PAYPAL_CLIENT_ID="your-paypal-client-id"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Rapid Radio Gear"

# Admin seed credentials (used by prisma seed)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"
